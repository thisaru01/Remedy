## Example environment variables for Remedy
# Copy this file to .env and fill in real secret values before running.

# JWT
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRE=1d

# internal service auth
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# service URLs (adjust for local or container networking)
AUTH_SERVICE_URL=http://auth-service:5000
PATIENT_SERVICE_URL=http://patient-service:5000
DOCTOR_SERVICE_URL=http://doctor-service:5000
APPOINTMENT_SERVICE_URL=http://appointment-service:5000
TELEMEDICINE_SERVICE_URL=http://telemedicine-service:5000
PAYMENT_SERVICE_URL=http://payment-service:5000

# MongoDB connection strings - replace <user>, <password>, <DB_NAME>
AUTH_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/auth_db?retryWrites=true&w=majority
PATIENT_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/patient_db?retryWrites=true&w=majority
DOCTOR_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/doctor_db?retryWrites=true&w=majority
APPOINTMENT_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/appointment_db?retryWrites=true&w=majority
TELEMEDICINE_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/telemedicine_db?retryWrites=true&w=majority
PAYMENT_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/paymentservice_db?retryWrites=true&w=majority
AI_MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/ai_db?retryWrites=true&w=majority

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Feature toggles
SKIP_APPOINTMENT_VALIDATION=false

# JaaS (video) settings
JAAS_ENABLED=true
JAAS_DOMAIN=8x8.vc
JAAS_APP_ID=your_jaas_app_id
JAAS_KEY_ID=your_jaas_key_id
# For multiline private keys, keep the value quoted and escape newlines (or use a files-based secret in production):
JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<base64-private-key>\n-----END PRIVATE KEY-----"

# Email (Gmail app password or SMTP creds)
GMAIL_USER=your_email@example.com
GMAIL_APP_PASSWORD=your_app_password
EMAIL_FROM=Remedy <your_email@example.com>

# AI provider key
GEMINI_API_KEY=your_api_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_SUCCESS_URL=http://localhost:5173/patient/payments/success
STRIPE_CANCEL_URL=http://localhost:5173/patient/payments/cancel

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555
